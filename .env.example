# ─── OpenRouter (обязательно) ─────────────────────────
# Получите ключ на https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-ваш_ключ

# Модель (по умолчанию claude-sonnet-4, можно заменить)
# Список моделей: https://openrouter.ai/models
AI_MODEL=anthropic/claude-sonnet-4

# ─── Aspro.Cloud (обязательно) ────────────────────────
# URL MCP-сервера (не менять)
ASPRO_MCP_URL=https://mcp.aspro.cloud/mcp

# Код портала (из URL: mycompany.aspro.cloud → mycompany)
ASPRO_ACCOUNT_CODE=mycompany

# API-ключ (создайте в Настройки портала → Настройки API → Добавить)
ASPRO_API_KEY=ваш_api_ключ
